# Copy this file to .env and fill in real values.
# .env should be in .gitignore -- never commit real credentials.

# ---- Source = the production server's Postgres ----
SOURCE_DB_HOST=your.server.ip
SOURCE_DB_PORT=5432
SOURCE_DB_NAME=production_db
SOURCE_DB_USER=sync_reader
SOURCE_DB_PASSWORD=
SOURCE_DB_SSLMODE=require

# ---- Local = the destination VPS's Postgres ----
LOCAL_DB_HOST=your.vps.ip
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=local_db
LOCAL_DB_USER=sync_writer
LOCAL_DB_PASSWORD=
LOCAL_DB_SSLMODE=require

# ---- API's own lightweight state (sync cursor, lock, run history) ----
# Point this at persistent disk, NOT /tmp, so it survives a reboot.
SYNC_META_DB_PATH=/var/lib/db_sync_api/sync_meta.db
SYNC_LOCK_FILE=/tmp/db_sync_api.lock

# ---- Security (required) ----
# Random key the caller must send as the X-API-Key header on every request.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SYNC_API_KEY=

# If the caller is allowed to override source_db/local_db per-request, only
# these hosts may be targeted. Comma-separated, no spaces.
# Keep this populated in production if request-level overrides are enabled.
# Leave blank only if the API always uses .env and never accepts DB overrides.
ALLOWED_DB_HOSTS=your.server.ip,your.vps.ip
